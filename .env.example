PORT=3000
PUBLIC_BASE_URL=https://your-public-domain.example.com
LOG_LEVEL=info
TRUST_PROXY=true

TWILIO_AUTH_TOKEN=replace-with-your-twilio-auth-token
TWILIO_VALIDATE_SIGNATURES=true

ULTRAVOX_API_KEY=replace-with-your-ultravox-api-key
ULTRAVOX_API_BASE_URL=https://api.ultravox.ai/api
ULTRAVOX_AGENT_ID=replace-with-your-ultravox-agent-id
ULTRAVOX_RECORDING_ENABLED=false
ULTRAVOX_JOIN_TIMEOUT=30s
ULTRAVOX_MAX_DURATION=1800s
ULTRAVOX_WEBHOOK_SECRET=replace-with-a-secret-at-least-16-characters

TOOLS_API_KEY=replace-with-random-hex-min-32-chars

CALL_STORE_DRIVER=supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-your-service-role-key
SUPABASE_CALLS_TABLE=phone_calls

CALL_STORE_PATH=./data/calls.json

# ── Nettu-scheduler (nittei) — required for calendar tools ────────────────────
# Point NETTU_BASE_URL at your running nettu-scheduler (self-hosted or cloud).
# The NETTU_API_KEY is the account-level API key created when you set up nettu.
NETTU_BASE_URL=https://your-nettu-scheduler.example.com
NETTU_API_KEY=replace-with-your-nettu-account-api-key
# NETTU_DB_PASSWORD is only needed when running your own nettu-scheduler server,
# not by this application's HTTP client.
NETTU_DB_PASSWORD=replace-with-your-nettu-db-password
